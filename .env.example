# TOTO WC-2026 — environment. Copy to .env and fill in. NEVER commit .env.
# All values are server-only; nothing here is exposed to the browser bundle
# (Next.js only ships variables prefixed with NEXT_PUBLIC_).

# --- Database -------------------------------------------------------------
# Local dev (docker postgres on 5433); on the VPS this points at the db service.
DATABASE_URL=postgres://toto:toto@localhost:5433/toto

# Postgres container credentials (used by docker-compose db service / .env).
POSTGRES_USER=toto
POSTGRES_PASSWORD=toto
POSTGRES_DB=toto

# --- Auth -----------------------------------------------------------------
# openssl rand -hex 32
JWT_SECRET=change-me-please-64-hex-chars-minimum-for-production-use-only
# From BotFather. Never expose to the client.
BOT_TOKEN=0000000000:DUMMY_BOT_TOKEN_FOR_LOCAL_DEV
BOT_USERNAME=toto_wc2026_bot
# Telegram numeric id that should be auto-granted admin on first login (optional).
ADMIN_TELEGRAM_ID=
# Public bot username for the Login Widget on the client (safe to expose).
NEXT_PUBLIC_BOT_USERNAME=toto_wc2026_bot

# Enable the dev-only password-less login endpoint (/api/auth/dev) for local
# development and Playwright E2E. MUST be unset/false in production.
ALLOW_DEV_LOGIN=true
# Mirror flag exposed to the client so the login screen shows the dev panel.
NEXT_PUBLIC_ALLOW_DEV_LOGIN=true

# --- Live results feed (Phase 2; optional in Phase 1) ---------------------
FD_TOKEN=

# --- Google Sheets export (optional in Phase 1) ---------------------------
# JSON content of the service-account key (single line).
GOOGLE_SA_JSON=
# Single private spreadsheet id for Phase 1 (public/redacted split is Phase 2).
SHEET_ID=
